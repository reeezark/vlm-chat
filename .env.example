# 基础运行模式
APP_ENV=development
FRONTEND_MODE=react

# 默认模型 Provider：dashscope / openai / openrouter / ollama
DEFAULT_PROVIDER=openai

# 通用默认模型名；当 DEFAULT_PROVIDER=openai 时也会作为 OpenAI 兼容默认模型
MODEL_NAME=qwen-vl-plus

# OpenAI 兼容接口配置
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your-openai-compatible-api-key
# 可选：覆盖 OpenAI Provider 下拉模型列表，多个模型用英文逗号分隔
# OPENAI_MODELS=qwen-vl-plus,qwen-vl-max,gpt-4o
# 可选：只覆盖 OpenAI Provider 默认模型
# OPENAI_MODEL_NAME=qwen-vl-plus

# DashScope 原生 Provider 配置
DASHSCOPE_API_KEY=

# OpenRouter / Ollama
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=

# 生产或对外部署时必须配置鉴权
GRADIO_AUTH_USER=
GRADIO_AUTH_PASSWORD=

# 稳定性与上传限制
REQUESTS_PER_MINUTE=20
MAX_IMAGES_PER_MESSAGE=4
MAX_DOC_SIZE_MB=10
MAX_PDF_PAGES=20
UPLOAD_RETENTION_SECONDS=604800

# 工具调用 / 知识库
ENABLE_TOOLS=true
ENABLE_RAG=true
RAG_TOP_K=3
