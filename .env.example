# 运行环境：development / production
# production 且对外监听或开启 share 时，必须配置 GRADIO_AUTH_USER/GRADIO_AUTH_PASSWORD
APP_ENV=development

# 阿里云DashScope API密钥配置
DASHSCOPE_API_KEY=your-api-key-here
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=

# 模型配置
DEFAULT_PROVIDER=dashscope
MODEL_NAME=qwen-vl-plus
SYSTEM_PROMPT=你是一个有帮助的多模态智能助手，擅长理解图片并用简洁、准确的中文回答用户问题。

# Gradio 服务配置
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
GRADIO_AUTH_USER=
GRADIO_AUTH_PASSWORD=

# 安全与限流
REQUESTS_PER_MINUTE=20
DEFAULT_USERNAME=local-user
DEFAULT_USER_ID=local-user

# 工具调用 / 联网搜索
ENABLE_TOOLS=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=8
WEB_SEARCH_MAX_QUERY_CHARS=200
WEB_SEARCH_MAX_RESULT_CHARS=2000

# 上传与文档处理
MAX_IMAGES_PER_MESSAGE=4
MAX_DOC_SIZE_MB=10
MAX_DOC_TEXT_CHARS=8000
MAX_PDF_PAGES=20
UPLOAD_RETENTION_SECONDS=604800

# 性能
IMAGE_BASE64_CACHE_SIZE=128

# RAG MVP（轻量知识库检索增强）
ENABLE_RAG=true
RAG_DEFAULT_COLLECTION=默认知识库
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=3
RAG_EMBEDDING_DIM=128
